@using Cipher_Notes.Models
@using Cipher_Notes.Services

@page "/"
@inject NoteService NoteService

<div class="container">
    <div class="header">
        <div class="logo">
            <span class="shield-icon">🛡️</span>
            <div>
                <h1>SecureNotes</h1>
                <p>@notes.Count notes encrypted</p>
            </div>
        </div>
    </div>

    <input type="text" placeholder="🔍 Search notes..." class="search-bar" @bind="searchQuery" />

    @if (notes.Count == 0)
    {
        <div class="empty-state">
            <span class="shield-big">🛡️</span>
            <h2>No notes yet</h2>
            <p>Tap + to create your first encrypted note</p>
        </div>
    }
    else
    {
        <div class="notes-list">
            @foreach (var note in FilteredNotes)
            {
                <div class="note-card">
                    <h3>@note.Title</h3>
                    <p>@note.Created_at.ToString("dd/MM/yyyy")</p>
                </div>
            }
        </div>
    }

    <button class="new-note-btn" @onclick="GoToCreate">+ New Encrypted Note</button>
</div>

@code {
    private List<SecureNotes> notes = new();
    private string searchQuery = "";

    private IEnumerable<SecureNotes> FilteredNotes =>
        notes.Where(n => n.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        notes = await NoteService.GetAllNotes();
    }

    private void GoToCreate()
    {
        // navigation εδώ
    }
}
